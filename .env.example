# KayaFlow Environment Configuration
# Copy this to .env and fill in your values

# === REQUIRED ===

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Anthropic Claude API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# === OPTIONAL ===

# Model selection (defaults shown)
CLAUDE_CRITIQUE_MODEL=claude-sonnet-4-6
CLAUDE_QUICK_MODEL=claude-haiku-4-5-20251001

# Memory store path (default: ./memory/store.json)
MEMORY_STORE_PATH=./memory/store.json

# Design memory path (default: ./design-memory)
DESIGN_MEMORY_PATH=./design-memory

# Enable OCR text extraction from screenshots (requires pytesseract + tesseract binary)
OCR_ENABLED=false

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Max conversation history to retain per user (turns)
MAX_CONVERSATION_HISTORY=10

# Rate limiting (requests per user per hour, 0 = unlimited)
RATE_LIMIT_PER_HOUR=20

# Webhook mode (for production deployment)
# Leave empty for polling mode (development)
WEBHOOK_URL=
WEBHOOK_PORT=8443

# Bot admin Telegram user ID (for /admin commands)
ADMIN_USER_ID=
